# Copy this file to .env on the server, then replace every CHANGE_ME value.
# 将本文件复制为服务器上的 .env，然后替换所有 CHANGE_ME 配置。

ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_RANDOM_APPLICATION_SECRET
UVICORN_WORKERS=2

# Image locations are configurable for servers that cannot reach Docker Hub.
# Docker Hub 不可访问时，把这些值改为阿里云 ACR、Harbor 或其他可信私有仓库地址。
PYTHON_BASE_IMAGE=python:3.13-slim
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.14.1
NGINX_IMAGE=nginx:1.27-alpine
PIP_INDEX_URL=https://pypi.org/simple

# Only Nginx is published. Keep 5432, 6333, 6379 and 9003 private.
# 只公开 Nginx；PostgreSQL、Qdrant、Redis 和 Agent 端口保持容器内部访问。
PUBLIC_BIND_IP=0.0.0.0
PUBLIC_PORT=8080
CORS_ALLOWED_ORIGINS=https://superset.example.com
ENABLE_DEBUG_UI=false
ENABLE_USAGE_UI=true
ALLOW_WEBSOCKET_QUERY_TOKEN=false

# PostgreSQL container and application connection.
# PostgreSQL 容器初始化配置；三个基础设施密码可以使用同一值，但不建议长期共用。
POSTGRES_DB=superset_agent_service
POSTGRES_USER=agent_service
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Redis is provisioned for future cache and queue work. Current Agent code does
# not consume it yet, but the URL is already injected into the container.
# Redis 用于后续缓存和队列；当前 Agent 业务代码尚未消费它，但连接地址已注入容器。
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Qdrant requires an API key even though its port is private.
# Qdrant 即使只在容器内访问，也必须配置 API Key。
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY
QDRANT_COLLECTION=superset_agent_knowledge
QDRANT_MEMORY_COLLECTION=superset_agent_memory
SEMANTIC_MEMORY_TOP_K=5

# On Linux, Compose maps host.docker.internal to the Docker host gateway.
# 如果 Superset runs elsewhere, replace these values with its private HTTPS URL.
# Linux Compose 会把 host.docker.internal 映射到宿主机；Superset 在其他服务器时请改为内网 HTTPS 地址。
SUPERSET_MCP_URL=http://host.docker.internal:9009/mcp
SUPERSET_MCP_TOKEN=
SUPERSET_AGENT_TOKEN_VERIFY_URL=http://host.docker.internal:9000/api/v1/agent/token/verify
SUPERSET_AGENT_SERVICE_KEY=CHANGE_ME_SERVICE_TO_SERVICE_SECRET
AGENT_TOKEN_VERIFY_CACHE_SECONDS=60
AGENT_DELEGATE_AUTH_TO_MCP=true

# DeepSeek OpenAI-compatible model.
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=CHANGE_ME_DEEPSEEK_API_KEY
OPENAI_MODEL=deepseek-chat
MAX_AGENT_STEPS=24
MAX_RUN_SECONDS=240
MAX_SQL_ROWS=1000
AGENT_GUIDED_MODE=false

# RAG and semantic memory.
RAG_ENABLED=true
RAG_TOP_K=5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
DASHSCOPE_API_KEY=CHANGE_ME_DASHSCOPE_API_KEY
DASHSCOPE_EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings

# Aliyun OSS.
OSS_REGION=cn-beijing
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_BUCKET=rag-superset
OSS_ACCESS_KEY_ID=CHANGE_ME_OSS_ACCESS_KEY_ID
OSS_ACCESS_KEY_SECRET=CHANGE_ME_OSS_ACCESS_KEY_SECRET
OSS_PREFIX=superset-agent-knowledge

RUN_MCP_INTEGRATION_TESTS=false
