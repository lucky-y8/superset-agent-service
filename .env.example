PROJECT_NAME=superset-agent-service
ENVIRONMENT=local
SECRET_KEY=change-me

# PostgreSQL is the durable runtime database used by Run Trace persistence.
# 本地 PostgreSQL 账号、密码和数据库名请按实际环境修改。
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/superset_agent_service

# Local Superset MCP Streamable HTTP endpoint.
SUPERSET_MCP_URL=http://127.0.0.1:9009/mcp
SUPERSET_MCP_TOKEN=

# Superset endpoint used by Agent Service to verify short-lived Agent tokens.
# Agent Service 用来向 Superset 校验短期 Agent Token 的接口。
SUPERSET_AGENT_TOKEN_VERIFY_URL=http://127.0.0.1:8088/api/v1/agent/token/verify

# Optional service-to-service secret. Keep empty if Superset does not require it yet.
# 可选服务间密钥；如果 Superset 校验接口暂未要求，可先留空。
SUPERSET_AGENT_SERVICE_KEY=

# DeepSeek uses the OpenAI-compatible chat-completions protocol.
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat

MAX_AGENT_STEPS=24
MAX_RUN_SECONDS=240
MAX_SQL_ROWS=1000

# RAG knowledge base. Keep secrets in your local .env; do not commit them.
# RAG 知识库配置。密钥只放本地 .env，不要提交到代码仓库。
RAG_ENABLED=false
RAG_TOP_K=5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120

# DashScope / Tongyi embedding.
# 通义 DashScope 向量模型配置。
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings

# Qdrant vector database.
# Qdrant 向量数据库配置。
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=superset_agent_knowledge
QDRANT_MEMORY_COLLECTION=superset_agent_memory
QDRANT_API_KEY=
SEMANTIC_MEMORY_TOP_K=5

# Aliyun OSS object storage for original uploaded files.
# 阿里云 OSS 对象存储，用于保存上传的原始文件。
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PREFIX=superset-agent-knowledge
